{
  "name": "easyviewerpdf",
  "version": "1.0.1",
  "description": "Open a PDF, split it into pages, and view multiple pages side by side.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win nsis"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "pdfjs-dist": "^4.8.69"
  },
  "build": {
    "appId": "com.easyviewerpdf.app",
    "productName": "EasyViewerPDF",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "package.json",
      "!node_modules/@napi-rs/**",
      "!node_modules/pdfjs-dist/legacy/**",
      "!node_modules/pdfjs-dist/web/**",
      "!node_modules/pdfjs-dist/types/**",
      "!node_modules/pdfjs-dist/build/*.map",
      "!node_modules/pdfjs-dist/build/*.min.mjs",
      "!node_modules/pdfjs-dist/build/pdf.sandbox*"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
